# ZenPaper Keystore Properties Template
# Copy this file to keystore.properties and fill in your values
# NEVER commit keystore.properties to version control!

# Local keystore file path (relative to project root)
storeFile=../zenpaper.jks
storePassword=YOUR_STORE_PASSWORD
keyAlias=zenpaper
keyPassword=YOUR_KEY_PASSWORD

# For CI/CD, use environment variables instead:
# KEYSTORE_PATH
# KEYSTORE_PASSWORD
# KEY_ALIAS
# KEY_PASSWORD