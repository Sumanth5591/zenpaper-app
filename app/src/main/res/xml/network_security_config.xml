<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Enforce HTTPS for all domains by default -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Specific domain configurations with certificate pinning -->
    <domain-config>
        <domain includeSubdomains="true">wallhaven.cc</domain>
        <domain includeSubdomains="true">wallwidgy.vercel.app</domain>
        <domain includeSubdomains="true">raw.githubusercontent.com</domain>
        <domain includeSubdomains="true">www.wallwidgy.app</domain>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
        <!--
        Pin certificates for critical domains (prevents MITM)
        To generate pins: openssl s_client -servername DOMAIN -connect DOMAIN:443 | openssl x509 -pubkey -noout | openssl pkey -pubin -outform der | openssl dgst -sha256 -binary | base64
        -->
        <!-- <pin-set expiration="2026-12-31">
            <pin algorithm="SHA-256">BASE64_PIN_HERE</pin>
            <pin algorithm="SHA-256">BACKUP_BASE64_PIN_HERE</pin>
        </pin-set> -->
    </domain-config>

    <!-- Debug configuration (only for debug builds) -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>
</network-security-config>